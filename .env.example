# --- LLM Settings ---
# 使用するLLMのモデル（LiteLLM 使用）
LITELLM_MODEL=
# API Key
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# LLM応答タイムアウト時間
LLM_TIMEOUT=20.0

# 会話履歴として保持する最大履歴数
MAX_HISTORY=40


# --- Audio Settings ---
# デバイス名は部分一致で検索されます（例: "Voicemeeter Out A1" など）
# 指定がない（空の）場合は AUDIO_INPUT_DEVICE_INDEX が使用されます（未設定の場合、既定のデバイス）
AUDIO_INPUT_DEVICE_NAME=
AUDIO_INPUT_DEVICE_INDEX=

# 出力側も同様に部分一致で検索されます
AUDIO_OUTPUT_DEVICE_NAME=
AUDIO_OUTPUT_DEVICE_INDEX=

# STT (Faster-Whisper) のモデルサイズ (tiny, base, small, medium, large-v3 など)
STT_MODEL_SIZE=medium

# STTの動作デバイス (指定がない場合はGPU(CUDA)の有無を自動検出します。強制したい場合は cpu または cuda を指定)
# STT_DEVICE=
# STTの演算精度 (指定がない場合はGPU時 float16、CPU時 int8 が自動選択されます。cpuで動作させる場合は int8 が推奨されます)
# STT_COMPUTE_TYPE=

# 話者識別 (Speaker Identification) ※未調整機能のため、無効化
# true にすると、話者識別が有効になり、発話者の名前やIDがメッセージに付与与えられます。
# 未知の話者の場合でも無視されず、自動登録されたうえで [Unknown id_...]: の形式で付与されます。
SPEAKER_GATE_ENABLED=false
# 話者データを保存する SQLite のパス（プロジェクトルートからの相対パス）
SPEAKER_GATE_DB_PATH=data/speakers.db
# マッチング判定のコサイン類似度しきい値（0.0〜1.0、高いほど厳しく判定）
SPEAKER_GATE_THRESHOLD=0.72

# VOICEVOX設定
VOICEVOX_URL="http://127.0.0.1:50021"
VOICEVOX_SPEAKER_ID=46


# --- Vision Settings ---
# Spout経由でキャプチャする映像の送信者名
SPOUT_SENDER_NAME=VRCSender1
# 画像の上下を反転させるフラグ。VRC画像が上下反転して取得されるのを正すための機能。(1: 有効, 0: 無効)
SPOUT_FLIP_TOP_BOTTOM_IMAGE=1

# LLMに送る画像の最大横幅
VISION_MAX_WIDTH=800
# 保存・送信時のJPEG品質
VISION_JPEG_QUALITY=80

# 画像の保存（ファイル書き出し）を有効にするかどうか (1: 有効, 0: 無効)
SAVE_VISION_IMAGES=0
# 画像ログの保存先ディレクトリ
VISION_LOG_DIR=logs


# --- Logging Settings ---
# 標準エラー出力のログレベル (DEBUG / INFO / WARNING / ERROR)
LOG_STDERR_LEVEL=INFO
# 標準エラー出力へのログ出力 (1: 有効, 0: 無効)
LOG_STDERR_ENABLED=1
# 通常ログファイルへの出力 (1: 有効, 0: 無効)
LOG_FILE_ENABLED=0
# チャット履歴専用ログファイルへの出力 (1: 有効, 0: 無効)
LOG_CHAT_FILE_ENABLED=0
